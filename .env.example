# Server Configuration
PORT=5000
NODE_ENV=development

# Session Configuration
# IMPORTANT: Change this to a strong random string in production!
SESSION_SECRET=your-secret-key-change-in-production

# Database Configuration
DB_PATH=./database/library.db

# MinIO Object Storage Configuration
# Get these credentials from your MinIO server admin panel
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_USE_SSL=false

# MinIO Bucket Names (default values)
MINIO_BUCKET_COVERS=book-covers
MINIO_BUCKET_EBOOKS=ebooks
MINIO_BUCKET_PHOTOS=user-photos

# Application Constants
# Fine amount in IDR per day for overdue books
FINE_PER_DAY=1000
# Number of days a book can be borrowed
BORROW_DAYS=7
