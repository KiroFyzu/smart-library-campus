<div class="container-fluid">
  <h4 class="fw-bold mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard Administrator</h4>

  <!-- Stats Cards -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-2">
      <div class="card stat-card bg-primary text-white">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="small opacity-75">Total Buku</div>
            <div class="fs-3 fw-bold"><%= stats.totalBooks %></div>
          </div>
          <i class="bi bi-book stat-icon"></i>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="card stat-card bg-info text-white">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="small opacity-75">Kategori</div>
            <div class="fs-3 fw-bold"><%= stats.totalCategories %></div>
          </div>
          <i class="bi bi-tags stat-icon"></i>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="card stat-card bg-success text-white">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="small opacity-75">User Aktif</div>
            <div class="fs-3 fw-bold"><%= stats.totalUsers %></div>
          </div>
          <i class="bi bi-people stat-icon"></i>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="card stat-card bg-warning text-dark">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="small opacity-75">Dipinjam</div>
            <div class="fs-3 fw-bold"><%= stats.activeBorrows %></div>
          </div>
          <i class="bi bi-journal-arrow-down stat-icon"></i>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="card stat-card bg-danger text-white">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="small opacity-75">Terlambat</div>
            <div class="fs-3 fw-bold"><%= stats.overdueCount %></div>
          </div>
          <i class="bi bi-exclamation-triangle stat-icon"></i>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-2">
      <div class="card stat-card bg-secondary text-white">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="small opacity-75">Dikembalikan</div>
            <div class="fs-3 fw-bold"><%= stats.returnedCount %></div>
          </div>
          <i class="bi bi-arrow-return-left stat-icon"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <!-- Chart -->
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
          <h6 class="fw-bold mb-0">Tren Peminjaman Bulanan</h6>
        </div>
        <div class="card-body">
          <canvas id="monthlyChart" height="200"></canvas>
        </div>
      </div>
    </div>

    <!-- Recent Borrowings -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3">
          <h6 class="fw-bold mb-0">Peminjaman Terbaru</h6>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive" style="max-height: 350px; overflow-y: auto;">
            <table class="table table-sm mb-0">
              <thead class="sticky-top bg-white">
                <tr>
                  <th>User</th>
                  <th>Buku</th>
                  <th>Tanggal</th>
                </tr>
              </thead>
              <tbody>
                <% if (recentBorrowings.length === 0) { %>
                  <tr><td colspan="3" class="text-center text-muted py-3">Belum ada data.</td></tr>
                <% } else { %>
                  <% recentBorrowings.forEach(b => { %>
                    <tr>
                      <td class="small"><%= b.user_name %></td>
                      <td class="small text-truncate" style="max-width: 150px;"><%= b.book_title %></td>
                      <td class="small text-muted"><%= b.borrow_date %></td>
                    </tr>
                  <% }); %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
  const monthlyData = JSON.parse('<%- JSON.stringify(monthlyStats) %>');
  if (monthlyData.length > 0) {
    new Chart(document.getElementById('monthlyChart'), {
      type: 'bar',
      data: {
        labels: monthlyData.map(d => d.month),
        datasets: [{
          label: 'Jumlah Peminjaman',
          data: monthlyData.map(d => d.count),
          backgroundColor: 'rgba(102, 126, 234, 0.7)',
          borderRadius: 6
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
      }
    });
  }
</script>
