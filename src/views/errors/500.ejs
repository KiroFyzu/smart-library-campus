<div class="error-page">
  <div class="error-code">500</div>
  <h3 class="mt-2">Terjadi Kesalahan Server</h3>
  <p class="text-muted">Maaf, terjadi kesalahan pada server. Silakan coba lagi.</p>
  <% if (locals.error && error.message) { %>
    <div class="alert alert-danger mt-3 text-start" style="max-width: 500px;">
      <strong>Error:</strong> <%= error.message %>
    </div>
  <% } %>
  <a href="/" class="btn btn-primary mt-3"><i class="bi bi-house me-1"></i> Kembali ke Beranda</a>
</div>
