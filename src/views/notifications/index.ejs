<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bell me-2"></i>Notifikasi</h4>
    <form action="/notifications/read-all" method="POST">
      <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-check2-all me-1"></i> Tandai Semua Dibaca</button>
    </form>
  </div>

  <% if (notifications.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-bell-slash fs-1 text-muted"></i>
      <p class="text-muted mt-2">Tidak ada notifikasi.</p>
    </div>
  <% } else { %>
    <div class="list-group shadow-sm">
      <% notifications.forEach(n => { %>
        <div class="list-group-item notif-item <%= n.is_read ? '' : 'unread' %> d-flex align-items-start gap-3">
          <div class="mt-1">
            <% if (n.type === 'success') { %>
              <i class="bi bi-check-circle-fill text-success fs-4"></i>
            <% } else if (n.type === 'warning') { %>
              <i class="bi bi-exclamation-triangle-fill text-warning fs-4"></i>
            <% } else if (n.type === 'error') { %>
              <i class="bi bi-x-circle-fill text-danger fs-4"></i>
            <% } else { %>
              <i class="bi bi-info-circle-fill text-primary fs-4"></i>
            <% } %>
          </div>
          <div class="flex-grow-1">
            <div class="d-flex justify-content-between">
              <h6 class="mb-1 fw-semibold"><%= n.title %></h6>
              <small class="text-muted"><%= new Date(n.created_at).toLocaleString('id-ID') %></small>
            </div>
            <p class="mb-1 text-muted"><%= n.message %></p>
          </div>
          <% if (!n.is_read) { %>
            <button class="btn btn-sm btn-link text-primary mark-read-btn" data-id="<%= n.id %>" title="Tandai dibaca">
              <i class="bi bi-check2"></i>
            </button>
          <% } %>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
  document.querySelectorAll('.mark-read-btn').forEach(btn => {
    btn.addEventListener('click', async function() {
      const id = this.dataset.id;
      await fetch('/notifications/' + id + '/read', { method: 'POST' });
      this.closest('.notif-item').classList.remove('unread');
      this.remove();
    });
  });
</script>
