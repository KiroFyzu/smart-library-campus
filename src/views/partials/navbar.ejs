<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4">
  <button class="btn btn-primary d-lg-none me-2" id="sidebarToggle">
    <i class="bi bi-list"></i>
  </button>
  <span class="navbar-brand fw-bold text-primary d-none d-lg-block">
    <i class="bi bi-book-half me-1"></i> <%= typeof title !== 'undefined' ? title : 'Dashboard' %>
  </span>
  <div class="ms-auto d-flex align-items-center gap-3">
    <% if (locals.user) { %>
      <a href="/notifications" class="btn btn-light position-relative">
