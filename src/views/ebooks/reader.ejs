<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-book me-2"></i><%= ebook.book_title %></h5>
    <div class="d-flex gap-2">
      <a href="/ebooks/<%= ebook.id %>/download" class="btn btn-sm btn-outline-success"><i class="bi bi-download me-1"></i> Download</a>
      <a href="/ebooks" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Kembali</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <iframe src="<%= pdfUrl %>" style="width: 100%; height: 80vh; border: none;" title="E-Book Reader"></iframe>
    </div>
  </div>
</div>
