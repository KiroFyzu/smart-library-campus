<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-file-earmark-pdf me-2"></i>Koleksi E-Book</h4>
    <% if (locals.user && user.role === 'admin') { %>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal"><i class="bi bi-upload me-1"></i> Upload E-Book</button>
    <% } %>
  </div>

  <div class="row g-3">
    <% if (ebooks.length === 0) { %>
      <div class="col-12 text-center py-5">
        <i class="bi bi-file-earmark-pdf fs-1 text-muted"></i>
        <p class="text-muted mt-2">Belum ada e-book tersedia.</p>
      </div>
    <% } else { %>
      <% ebooks.forEach(eb => { %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card book-card shadow-sm">
            <div class="book-placeholder" style="height: 140px;">
              <i class="bi bi-file-earmark-pdf"></i>
            </div>
            <div class="card-body">
              <div class="book-title text-dark"><%= eb.book_title %></div>
              <div class="book-author"><%= eb.file_name %></div>
              <small class="text-muted"><%= (eb.file_size / 1024 / 1024).toFixed(1) %> MB</small>
              <div class="d-flex gap-1 mt-2">
                <a href="/ebooks/<%= eb.id %>/read" class="btn btn-sm btn-outline-primary flex-grow-1"><i class="bi bi-book me-1"></i> Baca</a>
                <a href="/ebooks/<%= eb.id %>/download" class="btn btn-sm btn-outline-success"><i class="bi bi-download"></i></a>
                <% if (locals.user && user.role === 'admin') { %>
                  <form action="/ebooks/<%= eb.id %>/delete" method="POST" onsubmit="return confirmDelete('Hapus e-book ini?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>
</div>

<!-- Upload Modal (Admin) -->
<% if (locals.user && user.role === 'admin') { %>
<div class="modal fade" id="uploadModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/ebooks/0" method="POST" enctype="multipart/form-data" id="uploadForm">
        <div class="modal-header">
          <h5 class="modal-title">Upload E-Book</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Pilih Buku</label>
            <select name="bookId" id="ebookBookSelect" class="form-select" required>
              <option value="">-- Pilih Buku --</option>
              <% books.forEach(b => { %>
                <option value="<%= b.id %>"><%= b.title %></option>
              <% }); %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">File E-Book</label>
            <input type="file" name="ebook" class="form-control" accept=".pdf,.epub" required>
            <small class="text-muted">Format: PDF, EPUB. Maks 50MB.</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary">Upload</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('uploadForm');
    const select = document.getElementById('ebookBookSelect');
    form.addEventListener('submit', function(e) {
      const bookId = select.value;
      if (bookId) {
        form.action = '/ebooks/' + bookId;
      }
    });
  });
</script>
<% } %>
