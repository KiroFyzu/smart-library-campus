<div class="container-fluid">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-collection me-2"></i>Koleksi Buku</h4>
    <% if (locals.user && user.role === 'admin') { %>
      <a href="/books/create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Tambah Buku</a>
    <% } %>
  </div>

  <!-- Search & Filter -->
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
      <form action="/books" method="GET" class="row g-2">
        <div class="col-md-5">
          <div class="input-group">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" name="search" class="form-control" placeholder="Cari judul atau penulis..." value="<%= search %>">
          </div>
        </div>
        <div class="col-md-4">
          <select name="category" class="form-select">
            <option value="">Semua Kategori</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= selectedCategory === cat.id ? 'selected' : '' %>><%= cat.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="col-md-3">
          <button type="submit" class="btn btn-primary w-100"><i class="bi bi-search me-1"></i> Cari</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Book Grid -->
  <% if (books.length === 0) { %>
    <div class="text-center py-5">
      <i class="bi bi-inbox fs-1 text-muted"></i>
      <p class="text-muted mt-2">Tidak ada buku ditemukan.</p>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% books.forEach(book => { %>
        <div class="col-6 col-md-4 col-lg-3 col-xl-2">
          <a href="/books/<%= book.id %>" class="text-decoration-none">
            <div class="card book-card shadow-sm">
              <% if (book.cover_url) { %>
                <img src="<%= book.cover_url %>" class="card-img-top" alt="<%= book.title %>">
              <% } else { %>
                <div class="book-placeholder">
                  <i class="bi bi-book"></i>
                </div>
              <% } %>
              <div class="card-body">
                <div class="book-title text-dark"><%= book.title %></div>
                <div class="book-author"><%= book.author %></div>
                <div class="mt-2">
                  <% if (book.available > 0) { %>
                    <span class="badge bg-success">Tersedia (<%= book.available %>)</span>
                  <% } else { %>
                    <span class="badge bg-danger">Habis</span>
                  <% } %>
                </div>
              </div>
            </div>
          </a>
        </div>
      <% }); %>
    </div>

    <!-- Pagination -->
    <div class="mt-4">
      <%- include('../partials/pagination') %>
    </div>
  <% } %>
</div>
