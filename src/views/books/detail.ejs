<div class="container-fluid">
  <div class="row">
    <div class="col-lg-4 mb-4">
      <div class="card border-0 shadow-sm">
        <% if (locals.coverUrl) { %>
          <img src="<%= coverUrl %>" class="card-img-top rounded-top" alt="<%= book.title %>" style="max-height: 400px; object-fit: cover;">
        <% } else { %>
          <div class="book-placeholder" style="height: 300px; border-radius: 12px 12px 0 0;">
            <i class="bi bi-book"></i>
          </div>
        <% } %>
      </div>
    </div>
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <div class="book-detail-header d-flex justify-content-between align-items-start mb-3">
            <div>
              <h3 class="fw-bold"><%= book.title %></h3>
              <p class="text-muted mb-1"><i class="bi bi-person me-1"></i> <%= book.author %></p>
              <% if (book.category_name) { %>
                <span class="badge badge-soft-info"><%= book.category_name %></span>
              <% } %>
            </div>
            <% if (locals.user && user.role === 'admin') { %>
              <div class="page-actions">
                <a href="/books/<%= book.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                <form action="/books/<%= book.id %>/delete" method="POST" onsubmit="return confirmDelete('Hapus buku ini?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </div>
            <% } %>
          </div>

          <hr>

          <table class="table table-borderless mb-4">
            <tr><td class="text-muted" width="150">ISBN</td><td><%= book.isbn || '-' %></td></tr>
            <tr><td class="text-muted">Stok</td><td><%= book.stock %> buku</td></tr>
            <tr><td class="text-muted">Tersedia</td><td>
              <% if (book.available > 0) { %>
                <span class="badge badge-available"><%= book.available %> tersedia</span>
              <% } else { %>
                <span class="badge badge-unavailable">Tidak tersedia</span>
              <% } %>
            </td></tr>
          </table>

          <% if (book.description) { %>
            <h6 class="fw-bold">Deskripsi</h6>
            <p class="text-muted"><%= book.description %></p>
          <% } %>

          <% if (locals.user && user.role !== 'admin' && book.available > 0) { %>
            <form action="/borrow" method="POST" class="mt-3">
              <input type="hidden" name="book_id" value="<%= book.id %>">
              <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-journal-arrow-down me-2"></i>Pinjam Buku</button>
            </form>
          <% } %>

          <a href="/books" class="btn btn-outline-secondary mt-2"><i class="bi bi-arrow-left me-1"></i> Kembali</a>
        </div>
      </div>
    </div>
  </div>
</div>
